<!-- 候補日時の1行フォームパーシャル -->
<div class="candidate-row flex items-center gap-3 p-4 bg-white/5 border border-white/10 rounded-xl mb-3 transition-all duration-200 hover:border-indigo-400/40"
  data-nested-form-target="item">
  <%= fields.hidden_field :_destroy, class: "destroy-flag", value: "false" %>

  <div class="flex-1 grid grid-cols-2 gap-3">
    <div class="flex flex-col gap-1">
      <label class="text-xs text-slate-400 font-medium">開始日時</label>
      <%= fields.datetime_local_field :start_at,
          class: "w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400",
          step: 300 %>
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-slate-400 font-medium">終了日時</label>
      <%= fields.datetime_local_field :end_at,
          class: "w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400",
          step: 300 %>
    </div>
  </div>

  <button type="button"
    class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500/40 transition-colors duration-150 text-sm font-bold"
    data-action="click->nested-form#remove"
    data-nested-form-target="removeButton"
    title="削除">✕</button>
</div>
