<!-- 保存完了・共有URLページ -->
<!DOCTYPE html>
<html lang="ja">
<head>
  <title>らくスケ - 作成完了</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="UTF-8">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white font-sans flex flex-col">
  <header class="border-b border-white/10 backdrop-blur-sm bg-white/5">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center gap-3">
      <img src="/icon.png" alt="らくスケ" class="w-10 h-10 object-contain drop-shadow-md">
      <span class="text-xl font-bold bg-gradient-to-r from-indigo-300 to-violet-300 bg-clip-text text-transparent">らくスケ</span>
    </div>
  </header>

  <main class="max-w-xl mx-auto px-4 py-12 w-full">
    <div class="text-center mb-8">
      <div class="text-5xl mb-4">🎉</div>
      <h2 class="text-2xl font-bold text-white mb-2">イベントを作成しました！</h2>
      <p class="text-slate-400 text-sm">以下のURLを参加者に共有してください。</p>
    </div>

    <% if @is_owner %>
      <!-- オーナー向け編集バナー -->
      <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-amber-500/10 border border-amber-500/30 rounded-xl">
        <span class="text-lg">✏️</span>
        <div class="flex-1">
          <p class="text-sm font-semibold text-amber-300">あなたはこのイベントの作成者です</p>
          <p class="text-xs text-slate-400">タイトルや候補日時を変更することができます</p>
        </div>
        <%= link_to edit_event_path(@event),
            class: "flex-shrink-0 px-3 py-1.5 rounded-lg text-amber-400 text-xs font-semibold border border-amber-500/40 hover:bg-amber-500/10 transition-colors" do %>
          ✏️ 編集する
        <% end %>
      </div>
    <% end %>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 mb-6">
      <p class="text-xs font-semibold text-slate-400 mb-3 uppercase tracking-wider">📌 イベントタイトル</p>
      <p class="text-lg font-bold text-white mb-4"><%= @event.title %></p>

      <% if @event.description.present? %>
        <p class="text-xs font-semibold text-slate-400 mb-3 uppercase tracking-wider mt-6">📝 説明</p>
        <div class="text-sm text-slate-300 mb-6 leading-relaxed whitespace-pre-wrap"><%= @event.description %></div>
      <% else %>
        <div class="mb-6"></div>
      <% end %>

      <p class="text-xs font-semibold text-slate-400 mb-2 uppercase tracking-wider">🔗 参加者への共有URL</p>
      <div class="bg-black/30 border border-white/10 rounded-xl px-4 py-3 font-mono text-sm text-indigo-300 break-all select-all">
        <%= request.base_url %>/event/<%= @event.token %>/respond
      </div>
      <p class="text-xs text-slate-500 mt-2">※ このURLを参加者に共有してください</p>
    </div>

    <!-- 集計ページへのリンク -->
    <div class="bg-white/5 border border-white/10 rounded-2xl p-5 mb-6">
      <p class="text-xs font-semibold text-slate-400 mb-3 uppercase tracking-wider">📊 集計・管理</p>
      <%= link_to result_event_path(token: @event.token),
          class: "flex items-center gap-3 px-4 py-3 bg-indigo-500/10 border border-indigo-500/30 rounded-xl text-indigo-300 text-sm hover:bg-indigo-500/20 transition-colors" do %>
        <span class="text-lg">📊</span>
        <span class="font-medium">集計結果を確認する</span>
        <span class="ml-auto text-indigo-400/60 text-xs"><%= @event.attendances.count %>名回答済み →</span>
      <% end %>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 mb-6">
      <p class="text-xs font-semibold text-slate-400 mb-4 uppercase tracking-wider">📋 候補日時</p>
      <% @event.candidate_dates.each do |cd| %>
        <div class="flex items-center gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="text-indigo-400 text-sm">▸</span>
          <span class="text-white text-sm">
            <%= cd.start_at.strftime("%Y年%-m月%-d日(%a) %H:%M") %>
            〜
            <%= cd.end_at.strftime("%H:%M") %>
          </span>
        </div>
      <% end %>
    </div>

    <%= link_to "＋ 別のイベントを作成する", new_event_path,
        class: "block w-full text-center px-6 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 text-white font-semibold text-sm hover:from-indigo-400 hover:to-violet-400 transition-all duration-150" %>
  </main>
</body>
</html>
