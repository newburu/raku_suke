<!DOCTYPE html>
<html lang="ja">
<head>
  <title>らくスケ - スケジュール調整をもっとかんたんに</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="UTF-8">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white font-sans">

  <!-- ヘッダー -->
  <header class="border-b border-white/10 backdrop-blur-sm bg-white/5">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center text-lg">📅</div>
      <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-300 to-violet-300 bg-clip-text text-transparent">らくスケ</h1>
      <span class="text-slate-400 text-sm">スケジュール調整をかんたんに</span>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-8">

    <!-- フラッシュメッセージ -->
    <% flash.each do |type, msg| %>
      <div class="mb-6 px-4 py-3 rounded-xl
        <%= type == 'notice' ? 'bg-green-500/20 border border-green-500/30 text-green-300' : 'bg-red-500/20 border border-red-500/30 text-red-300' %>">
        <%= msg %>
      </div>
    <% end %>

    <!-- ページタイトル -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-white mb-2">新しいイベントを作成</h2>
      <p class="text-slate-400 text-sm">候補日時を入力して、参加者に共有できる調整ページを作成します。</p>
    </div>

    <%= form_with model: @event,
        data: { controller: "nested-form", nested_form_url_value: extract_schedule_events_path },
        class: "space-y-6" do |f| %>

      <!-- タイトル入力 -->
      <div class="card bg-white/5 border border-white/10 rounded-2xl p-6">
        <label class="block text-sm font-semibold text-slate-300 mb-2">
          イベントタイトル <span class="text-red-400">*</span>
        </label>
        <%= f.text_field :title,
            placeholder: "例：4月の懇親会の日程調整",
            class: "w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 transition-colors" %>
        <% if @event.errors[:title].any? %>
          <p class="mt-2 text-xs text-red-400"><%= @event.errors[:title].first %></p>
        <% end %>
      </div>

      <!-- AI抽出エリア -->
      <div class="card bg-gradient-to-br from-indigo-900/40 to-violet-900/40 border border-indigo-500/30 rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">✨</span>
          <p class="text-sm font-semibold text-indigo-300">AIで候補日時を自動抽出</p>
        </div>
        <p class="text-xs text-slate-400 mb-4">
          「来週の月曜午後か水曜の10〜15時」のような自由な文章で入力すると、AIが候補日時を自動で読み取ります。
        </p>
        <textarea id="ai-input-text"
          placeholder="例：明日の午後か、来週の月曜の夜、あさって10時〜15時でお願いします"
          rows="3"
          class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 transition-colors resize-y mb-4"
        ></textarea>

        <button type="button"
          class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 text-white text-sm font-semibold hover:from-indigo-400 hover:to-violet-400 active:scale-95 transition-all duration-150 disabled:opacity-50 disabled:cursor-not-allowed"
          data-action="click->nested-form#extractSchedule"
          data-nested-form-target="extractButton">
          <span data-nested-form-target="extractLabel">✨ AIで候補日時を抽出</span>
        </button>
      </div>

      <!-- 候補日時リスト -->
      <div class="card bg-white/5 border border-white/10 rounded-2xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-semibold text-slate-300">📋 候補日時リスト</p>
            <p class="text-xs text-slate-500 mt-0.5">AIが抽出した結果を確認・修正できます</p>
          </div>
          <button type="button"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-indigo-500/40 text-indigo-400 text-xs font-medium hover:bg-indigo-500/10 active:scale-95 transition-all duration-150"
            data-action="click->nested-form#addRow">
            ＋ 行を追加
          </button>
        </div>

        <!-- Turbo Streamの差し替えターゲット -->
        <div id="candidate_dates_list" data-nested-form-target="list">
          <%= f.fields_for :candidate_dates do |fields| %>
            <%= render "candidate_date_fields", fields: fields %>
          <% end %>
        </div>

        <!-- 行追加用テンプレート（非表示） -->
        <template data-nested-form-target="template">
          <%= f.fields_for :candidate_dates, CandidateDate.new, child_index: "NEW_RECORD" do |fields| %>
            <%= render "candidate_date_fields", fields: fields %>
          <% end %>
        </template>

        <p class="text-xs text-slate-500 mt-3">
          ※ AI抽出はあくまで「下書き」です。必ず内容をご確認のうえ保存してください。
        </p>
      </div>

      <!-- 送信ボタン -->
      <div class="flex justify-end">
        <%= f.submit "このイベントを保存する →",
            class: "px-8 py-3 rounded-xl bg-gradient-to-r from-emerald-500 to-teal-500 text-white font-semibold text-sm hover:from-emerald-400 hover:to-teal-400 active:scale-95 transition-all duration-150 cursor-pointer" %>
      </div>

    <% end %>
  </main>
</body>
</html>
