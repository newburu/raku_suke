<% content_for :title, "<%= @event.title %> - らくスケ 回答ページ" %>
<!-- ヘッダー -->
  <header class="border-b border-white/10 bg-white/5">
    <div class="max-w-2xl mx-auto px-4 py-4 flex items-center gap-3">
      <%= link_to root_path, class: "flex items-center gap-3 hover:opacity-80 transition-opacity" do %>
        <img src="/icon.png" alt="らくスケ" class="w-10 h-10 object-contain drop-shadow-md">
        <span class="text-xl font-bold bg-gradient-to-r from-indigo-300 to-violet-300 bg-clip-text text-transparent">らくスケ</span>
      <% end %>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-8">

    <!-- フラッシュ -->
    <% flash.each do |type, msg| %>
      <div class="mb-4 px-4 py-3 rounded-xl
        <%= type == 'alert' ? 'bg-red-500/20 border border-red-500/30 text-red-300' : 'bg-green-500/20 border border-green-500/30 text-green-300' %>">
        <%= msg %>
      </div>
    <% end %>

    <!-- イベント情報 -->
    <div class="mb-8">
      <p class="text-xs text-indigo-400 font-semibold uppercase tracking-wider mb-2">スケジュール調整</p>
      <h1 class="text-2xl font-bold text-white mb-2"><%= @event.title %></h1>
      <% if @event.description.present? %>
        <div class="text-slate-400 text-sm leading-relaxed whitespace-pre-wrap mt-3"><%= @event.description %></div>
      <% end %>
    </div>

    <% if @attendance.persisted? %>
      <!-- 既存回答がある場合のバナー -->
      <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-indigo-500/15 border border-indigo-500/30 rounded-xl">
        <span class="text-lg">✏️</span>
        <div class="flex-1">
          <p class="text-sm font-semibold text-indigo-300">以前の回答を編集中</p>
          <p class="text-xs text-slate-400">変更して送信すると上書き保存されます</p>
        </div>
        <%= button_to "🗑 削除",
            destroy_attendance_path(token: @event.token),
            method: :delete,
            form: { data: { turbo_confirm: "本当に回答を削除しますか？この操作は取り消せません。" } },
            class: "flex-shrink-0 px-3 py-1.5 rounded-lg text-red-400 text-xs hover:bg-red-500/10 transition-colors bg-transparent border border-red-500/30 cursor-pointer" %>
      </div>
    <% end %>

    <%= form_with url: attend_event_path(token: @event.token),
        data: { controller: "response-form" },
        class: "space-y-6" do |f| %>

      <!-- 名前入力 -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <label class="block text-sm font-semibold text-slate-300 mb-2" for="user_name_input">
          あなたのお名前 <span class="text-red-400">*</span>
        </label>
        <input type="text"
          id="user_name_input"
          name="attendance[user_name]"
          placeholder="例：田中 太郎"
          value="<%= @attendance.user_name %>"
          required
          class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 transition-colors">
        <% if @attendance.errors[:user_name].any? %>
          <p class="mt-2 text-xs text-red-400"><%= @attendance.errors[:user_name].first %></p>
        <% end %>
      </div>

      <!-- 候補日時ごとの回答 -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <p class="text-sm font-semibold text-slate-300 mb-1">各日程の都合を教えてください</p>
        <div class="flex items-center gap-4 mb-5 text-xs text-slate-400">
          <span class="flex items-center gap-1"><span class="text-green-400 font-bold text-base">○</span> 参加できる</span>
          <span class="flex items-center gap-1"><span class="text-yellow-400 font-bold text-base">△</span> たぶん参加できる</span>
          <span class="flex items-center gap-1"><span class="text-red-400 font-bold text-base">×</span> 参加できない</span>
        </div>

        <div class="space-y-3">
          <% @event.candidate_dates.order(:start_at).each do |cd| %>
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-4 bg-white/5 border border-white/10 rounded-xl">
              <!-- 日時表示 -->
              <div class="flex-1 text-sm text-white">
                <span class="font-semibold"><%= cd.start_at.strftime("%-m/%-d(%a)") %></span>
                <span class="text-slate-400 ml-2"><%= cd.start_at.strftime("%H:%M") %> 〜 <%= cd.end_at.strftime("%H:%M") %></span>
              </div>

              <!-- ○△× ボタングループ（JS で selected クラスを切り替え） -->
              <div class="flex gap-2" data-response-group>
                <!-- ○ ボタン -->
                <button type="button"
                  class="response-btn w-12 h-12 flex items-center justify-center rounded-xl border-2 border-white/20 text-slate-400 text-lg font-bold transition-all duration-150 hover:border-green-400/60 hover:bg-green-400/10 hover:text-green-300"
                  data-value="ok"
                  data-color="green"
                  onclick="selectResponse(this, 'attendance[responses][<%= cd.id %>]', 'ok')">○</button>

                <!-- △ ボタン -->
                <button type="button"
                  class="response-btn w-12 h-12 flex items-center justify-center rounded-xl border-2 border-white/20 text-slate-400 text-lg font-bold transition-all duration-150 hover:border-yellow-400/60 hover:bg-yellow-400/10 hover:text-yellow-300"
                  data-value="maybe"
                  data-color="yellow"
                  onclick="selectResponse(this, 'attendance[responses][<%= cd.id %>]', 'maybe')">△</button>

                <!-- × ボタン -->
                <button type="button"
                  class="response-btn w-12 h-12 flex items-center justify-center rounded-xl border-2 border-white/20 text-slate-400 text-lg font-bold transition-all duration-150 hover:border-red-400/60 hover:bg-red-400/10 hover:text-red-300"
                  data-value="ng"
                  data-color="red"
                  onclick="selectResponse(this, 'attendance[responses][<%= cd.id %>]', 'ng')">×</button>

                <!-- 実際の値を保持する hidden input（既存回答があれば初期値をセット） -->
                <% existing_value = (@attendance.responses || {}).transform_keys(&:to_s)[cd.id.to_s].to_s %>
                <input type="hidden" name="attendance[responses][<%= cd.id %>]" value="<%= existing_value %>" class="response-hidden-<%= cd.id %>">
              </div>
            </div>
          <% end %>
        </div>
      </div>


      <!-- コメント入力 -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <label class="block text-sm font-semibold text-slate-300 mb-2" for="comment_input">
          コメント <span class="text-slate-500 font-normal text-xs">（任意）</span>
        </label>
        <textarea
          id="comment_input"
          name="attendance[comment]"
          placeholder="例：午前中は少し早退になるかもしれません"
          rows="2"
          class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 transition-colors resize-none"><%= @attendance.comment %></textarea>
      </div>

      <!-- 送信ボタン -->
      <div class="flex justify-end">
        <button type="submit"
          class="px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 text-white font-semibold text-sm hover:from-indigo-400 hover:to-violet-400 active:scale-95 transition-all duration-150">
          回答する →
        </button>
      </div>

    <% end %>

    <!-- 集計を見るリンク -->
    <div class="mt-8 text-center">
      <%= link_to "📊 集計結果を見る", result_event_path(token: @event.token),
          class: "text-sm text-slate-400 hover:text-indigo-400 transition-colors underline underline-offset-4" %>
    </div>

  </main>
  <script>
    // ○△×ボタンの選択状態を制御する関数
    const COLORS = {
      green:  { border: '#818cf8', bg: 'rgba(74,222,128,0.2)',  text: '#86efac' },
      yellow: { border: '#facc15', bg: 'rgba(250,204,21,0.2)', text: '#fde047' },
      red:    { border: '#f87171', bg: 'rgba(248,113,113,0.2)', text: '#fca5a5' }
    };

    function selectResponse(btn, fieldName, value) {
      // 同じグループ内の全ボタンをリセット
      const group = btn.closest('[data-response-group]');
      group.querySelectorAll('.response-btn').forEach(b => {
        b.style.borderColor = '';
        b.style.backgroundColor = '';
        b.style.color = '';
        b.style.transform = '';
      });

      // 選択したボタンを強調
      const color = btn.dataset.color;
      const c = COLORS[color];
      btn.style.borderColor = c.border;
      btn.style.backgroundColor = c.bg;
      btn.style.color = c.text;
      btn.style.transform = 'scale(1.08)';

      // hidden input に値をセット（同一nameのものを取得）
      const hidden = group.querySelector('input[type="hidden"]');
      if (hidden) hidden.value = value;
    }

    // 既存の回答をページ読み込み時にボタンに反映する
    document.addEventListener('turbo:load', () => {
      document.querySelectorAll('[data-response-group]').forEach(group => {
        const hidden = group.querySelector('input[type="hidden"]');
        if (!hidden || !hidden.value) return;

        const existingValue = hidden.value;
        const targetBtn = group.querySelector(`.response-btn[data-value="${existingValue}"]`);
        if (targetBtn) {
          const color = targetBtn.dataset.color;
          const c = COLORS[color];
          targetBtn.style.borderColor = c.border;
          targetBtn.style.backgroundColor = c.bg;
          targetBtn.style.color = c.text;
          targetBtn.style.transform = 'scale(1.08)';
        }
      });
    });
  </script>
