<!DOCTYPE html>
<html lang="ja">
<head>
  <title>回答完了 - らくスケ</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="UTF-8">
  <%= csrf_meta_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white font-sans flex flex-col">
  <header class="border-b border-white/10 bg-white/5">
    <div class="max-w-2xl mx-auto px-4 py-4 flex items-center gap-3">
      <img src="/icon.png" alt="らくスケ" class="w-10 h-10 object-contain drop-shadow-md">
      <span class="text-xl font-bold bg-gradient-to-r from-indigo-300 to-violet-300 bg-clip-text text-transparent">らくスケ</span>
    </div>
  </header>

  <main class="max-w-md mx-auto px-4 py-16 w-full text-center">
    <div class="text-6xl mb-6">🎊</div>
    <h1 class="text-2xl font-bold text-white mb-3">回答が完了しました！</h1>
    <p class="text-slate-400 text-sm mb-8">
      「<%= @event.title %>」の日程調整への回答ありがとうございました。<br>
      主催者からの連絡をお待ちください。
    </p>

    <div class="space-y-3">
      <%= link_to "📊 集計結果を見る", result_event_path(token: @event.token),
          class: "block w-full px-6 py-3 rounded-xl bg-white/10 border border-white/20 text-white text-sm font-medium hover:bg-white/15 transition-colors text-center" %>
      <%= link_to "↩ 回答し直す", respond_event_path(token: @event.token),
          class: "block w-full px-6 py-3 rounded-xl text-slate-400 text-sm hover:text-white transition-colors text-center" %>

      <!-- 回答を削除する（確認ダイアログ付き） -->
      <%= button_to "🗑 回答を削除する",
          destroy_attendance_path(token: @event.token),
          method: :delete,
          form: { data: { turbo_confirm: "本当に回答を削除しますか？この操作は取り消せません。" } },
          class: "w-full px-6 py-3 rounded-xl text-red-400 text-xs hover:text-red-300 transition-colors bg-transparent border-0 cursor-pointer" %>
    </div>
  </main>
</body>
</html>
