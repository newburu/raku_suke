<!DOCTYPE html>
<html lang="ja">
<head>
  <title><%= @event.title %> - 集計結果 | らくスケ</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="UTF-8">
  <%= csrf_meta_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white font-sans">
  <header class="border-b border-white/10 bg-white/5">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center text-lg">📅</div>
      <span class="text-xl font-bold bg-gradient-to-r from-indigo-300 to-violet-300 bg-clip-text text-transparent">らくスケ</span>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8">
      <p class="text-xs text-indigo-400 font-semibold uppercase tracking-wider mb-2">📊 集計結果</p>
      <h1 class="text-2xl font-bold text-white mb-2"><%= @event.title %></h1>
      <% if @event.description.present? %>
        <div class="text-slate-400 text-sm leading-relaxed whitespace-pre-wrap mt-3 mb-2"><%= @event.description %></div>
      <% end %>
      <p class="text-slate-400 text-sm">
        <%= @attendances.count %>名が回答済み
      </p>
    </div>

    <% if @candidate_dates.any? %>
      <!-- 集計マトリクス（横スクロール対応） -->
      <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden mb-6">
        <div class="overflow-x-auto">
          <table class="w-full text-sm min-w-[600px]">
            <thead>
              <tr class="border-b border-white/10">
                <th class="px-5 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider w-36">
                  参加者名
                </th>
                <% @candidate_dates.each do |cd| %>
                  <th class="px-3 py-4 text-center text-xs font-semibold text-slate-400 min-w-[110px]">
                    <div class="text-white font-semibold"><%= cd.start_at.strftime("%-m/%-d(%a)") %></div>
                    <div class="text-slate-500 font-normal mt-0.5"><%= cd.start_at.strftime("%H:%M") %>〜<%= cd.end_at.strftime("%H:%M") %></div>
                  </th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <%# 集計行（各候補の○△×数を表示） %>
              <tr class="border-b border-white/10 bg-white/5">
                <td class="px-5 py-3 text-xs text-slate-400 font-semibold">集計</td>
                <% @candidate_dates.each do |cd| %>
                  <td class="px-3 py-3 text-center">
                    <div class="flex items-center justify-center gap-2 text-xs">
                      <% counts = @attendances.map { |a| (a.responses || {}).transform_keys(&:to_s)[cd.id.to_s] } %>
                      <span class="text-green-400 font-semibold">○<%= counts.count("ok") %></span>
                      <span class="text-yellow-400 font-semibold">△<%= counts.count("maybe") %></span>
                      <span class="text-red-400 font-semibold">×<%= counts.count("ng") %></span>
                    </div>
                  </td>
                <% end %>
              </tr>

              <%# 参加者ごとの回答行 %>
              <% @attendances.each do |attendance| %>
                <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                  <td class="px-5 py-4 font-medium text-white max-w-[160px]">
                    <div class="truncate" title="<%= attendance.user_name %>"><%= attendance.user_name %></div>
                    <% if attendance.comment.present? %>
                      <% comment_short = attendance.comment.length > 20 %>
                      <% if comment_short %>
                        <%# 長い場合：前半を表示してダイアログリンク %>
                        <button type="button"
                          data-comment-btn
                          class="text-xs text-indigo-400 hover:text-indigo-300 mt-0.5 text-left w-full transition-colors"
                          onclick="showComment(this, '<%= j(attendance.user_name) %>', '<%= j(attendance.comment) %>')"
                        >
                          💬 <%= attendance.comment.first(20) %>...
                        </button>
                      <% else %>
                        <%# 短い場合：そのまま表示 %>
                        <div class="text-xs text-slate-400 mt-0.5">💬 <%= attendance.comment %></div>
                      <% end %>
                    <% end %>
                  </td>
                  <% @candidate_dates.each do |cd| %>
                    <% response = (attendance.responses || {}).transform_keys(&:to_s)[cd.id.to_s] %>
                    <td class="px-3 py-4 text-center">
                      <% case response
                         when "ok" %>
                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-green-400/20 text-green-400 font-bold text-lg">○</span>
                      <% when "maybe" %>
                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-yellow-400/20 text-yellow-400 font-bold text-lg">△</span>
                      <% when "ng" %>
                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-red-400/20 text-red-400 font-bold text-lg">×</span>
                      <% else %>
                        <span class="text-slate-600">—</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>

              <% if @attendances.empty? %>
                <tr>
                  <td colspan="<%= @candidate_dates.count + 1 %>" class="px-5 py-10 text-center text-slate-500 text-sm">
                    まだ回答がありません。共有URLを送って参加者に回答してもらいましょう。
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- 共有URLカード -->
      <div class="bg-indigo-900/30 border border-indigo-500/30 rounded-2xl p-5">
        <p class="text-xs font-semibold text-indigo-300 mb-2">🔗 参加者への共有URL</p>
        <div class="bg-black/30 border border-white/10 rounded-xl px-4 py-3 font-mono text-sm text-indigo-300 break-all">
          <%= request.base_url %>/event/<%= @event.token %>/respond
        </div>
      </div>

    <% else %>
      <div class="text-center py-16 text-slate-500">
        <p>候補日時がまだ登録されていません。</p>
      </div>
    <% end %>

    <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
      <%= link_to respond_event_path(token: @event.token),
          class: "px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 text-white font-semibold text-sm hover:from-indigo-400 hover:to-violet-400 active:scale-95 transition-all duration-150" do %>
        📝 回答する（または回答を変更する）
      <% end %>
    </div>
  </main>

  <!-- 吹き出し風ポップオーバー（JS で位置を動的に調整） -->
  <div id="comment-popover"
    class="hidden fixed z-50 max-w-xs w-72"
    role="tooltip">
    <!-- 吹き出し本体 -->
    <div class="relative bg-indigo-950 border border-indigo-400/40 rounded-xl shadow-2xl shadow-indigo-900/60 p-4">
      <!-- 吹き出しの三角（上向き） -->
      <div id="popover-arrow-up"
        class="absolute -top-2 left-6 w-4 h-4 bg-indigo-950 border-l border-t border-indigo-400/40 rotate-45">
      </div>
      <!-- 吹き出しの三角（下向き） -->
      <div id="popover-arrow-down"
        class="hidden absolute -bottom-2 left-6 w-4 h-4 bg-indigo-950 border-r border-b border-indigo-400/40 rotate-45">
      </div>

      <div class="flex items-start justify-between gap-2 mb-2">
        <p class="text-xs font-semibold text-indigo-300" id="popover-name"></p>
        <button id="popover-close"
          class="flex-shrink-0 text-slate-500 hover:text-white transition-colors text-base leading-none mt-0.5">✕</button>
      </div>
      <p class="text-sm text-slate-200 leading-relaxed whitespace-pre-wrap" id="popover-body"></p>
    </div>
  </div>

  <script>
    const popover    = document.getElementById('comment-popover');
    const popName    = document.getElementById('popover-name');
    const popBody    = document.getElementById('popover-body');
    const arrowUp    = document.getElementById('popover-arrow-up');
    const arrowDown  = document.getElementById('popover-arrow-down');
    const closeBtn   = document.getElementById('popover-close');

    function showComment(btn, name, comment) {
      popName.textContent = '💬 ' + name;
      popBody.textContent = comment;
      popover.classList.remove('hidden');

      const rect      = btn.getBoundingClientRect();
      const popW      = 288; // w-72
      const popH      = popover.offsetHeight || 130;
      const margin    = 12;  // ボタンとの距離
      const scrollY   = window.scrollY;
      const scrollX   = window.scrollX;
      const vw        = window.innerWidth;
      const vh        = window.innerHeight;

      // 左右位置：ボタン左端に揃え、はみ出す場合は右に補正
      let left = rect.left + scrollX;
      if (left + popW > vw - 8) left = vw - popW - 8 + scrollX;
      if (left < 8) left = 8;

      const arrowLeft = Math.max(8, rect.left + scrollX - left + 8);

      // ボタンの下に出せるか判定
      const spaceBelow = vh - rect.bottom;
      if (spaceBelow >= popH + margin) {
        // ▼ ボタンの下に出す（三角は上向き）
        popover.style.top  = (rect.bottom + scrollY + margin) + 'px';
        popover.style.left = left + 'px';
        arrowUp.style.display   = 'block';
        arrowDown.style.display = 'none';
        arrowUp.style.left = arrowLeft + 'px';
      } else {
        // ▲ ボタンの上に出す（三角は下向き）
        popover.style.top  = (rect.top + scrollY - popH - margin) + 'px';
        popover.style.left = left + 'px';
        arrowUp.style.display   = 'none';
        arrowDown.style.display = 'block';
        arrowDown.style.left = arrowLeft + 'px';
      }
    }

    function hidePopover() {
      popover.classList.add('hidden');
    }

    closeBtn.addEventListener('click', hidePopover);

    // ポップオーバー外クリックで閉じる
    document.addEventListener('click', function(e) {
      if (!popover.classList.contains('hidden') &&
          !popover.contains(e.target) &&
          !e.target.closest('[data-comment-btn]')) {
        hidePopover();
      }
    });
  </script>
</body>
</html>
